<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Tienda Tech</title>

<style>
body {
  font-family: 'Segoe UI', sans-serif;
  margin: 0;
  background: #f8f9fa;
}

/* HEADER */
header {
  background: #0d1117;
  color: white;
  padding: 20px;
  text-align: center;
}

/* GRID PRODUCTOS */
.container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 25px;
  padding: 30px;
}

/* TARJETA PRODUCTO */
.producto {
  background: white;
  border-radius: 15px;
  padding: 20px;
  text-align: center;
  transition: 0.3s;
  box-shadow: 0 5px 15px rgba(0,0,0,0.08);
}

.producto:hover {
  transform: translateY(-5px);
}

/* IMAGEN */
.producto img {
  width: 100%;
  border-radius: 10px;
}

/* BOTÓN */
button {
  background: #111;
  color: white;
  border: none;
  padding: 12px;
  border-radius: 8px;
  cursor: pointer;
  width: 100%;
  font-weight: bold;
}

button:hover {
  background: #333;
}

/* CARRITO */
#carrito {
  position: fixed;
  right: 20px;
  top: 20px;
  background: white;
  padding: 15px;
  border-radius: 15px;
  width: 260px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.2);
}

#carrito h3 {
  margin-top: 0;
}
</style>

</head>

<body>

<header>
  <h1>⚡ TechStore</h1>
  <p>Productos tecnológicos modernos</p>
</header>

<div id="carrito">
  <h3>🛒 Carrito</h3>
  <ul id="lista"></ul>
  <button onclick="enviarWhatsApp()">Comprar</button>
</div>

<div class="container">

  <div class="producto">
    <img src="https://via.placeholder.com/300" alt="">
    <h3>Audífonos Bluetooth</h3>
    <p>$79.900</p>
    <button onclick="agregar('Audífonos Bluetooth - $79.900')">Agregar al carrito</button>
  </div>

  <div class="producto">
    <img src="https://via.placeholder.com/300" alt="">
    <h3>Smartwatch</h3>
    <p>$120.000</p>
    <button onclick="agregar('Smartwatch - $120.000')">Agregar al carrito</button>
  </div>

  <div class="producto">
    <img src="https://via.placeholder.com/300" alt="">
    <h3>Teclado Gamer</h3>
    <p>$150.000</p>
    <button onclick="agregar('Teclado Gamer - $150.000')">Agregar al carrito</button>
  </div>

</div>

<script>
let carrito = [];

function agregar(producto){
  carrito.push(producto);
  mostrar();
}

function mostrar(){
  let lista = document.getElementById("lista");
  lista.innerHTML = "";
  carrito.forEach(item => {
    let li = document.createElement("li");
    li.textContent = item;
    lista.appendChild(li);
  });
}

function enviarWhatsApp(){
  let numero = "573001234567"; // CAMBIA TU NÚMERO
  let mensaje = "Hola, quiero comprar:\n" + carrito.join("\n");
  let url = "https://wa.me/" + numero + "?text=" + encodeURIComponent(mensaje);
  window.open(url);
}
</script>

</body>
</html>
